{
  "id": "special-workspaces",
  "name": "Special Workspaces (Hyprland)",
  "version": "1.0.2",
  "minNoctaliaVersion": "4.4.0",
  "author": "Qholin",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Configurable Hyprland special workspaces indicator for the bar.",
  "tags": ["Bar", "Productivity", "Hyprland"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "mainIcon": "layout-grid",
      "expandDirection": "down",
      "primaryShowPill": false,
      "primarySymbolColor": "none",
      "primaryPillColor": "none",
      "primarySize": 0.9,
      "secondaryShowPill": true,
      "secondarySymbolColor": "none",
      "secondaryPillColor": "primary",
      "secondarySize": 0.9,
      "borderRadius": 1.0,
      "focusBorderColor": "primary",
      "panelBackgroundColor": "surface",
      "panelBackgroundEnabled": true,
      "workspaces": [
        {
          "name": "communication",
          "icon": "message"
        }
      ],
      "drawer": true,
      "hideEmptyWorkspaces": false
    }
  }
}
